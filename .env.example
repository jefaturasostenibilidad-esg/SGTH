# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL & SUPABASE_KEY: Configure these user secrets to enable persistent PostgreSQL hosting.
# The system supports both direct relational schema matching and monolithic backup fallbacks.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"

# RESEND_API_KEY: Configure this key to send real emails for user access requests and metric threshold alerts.
RESEND_API_KEY="re_123456789"
